    <changeSet id="test-seed-002-1-customer" author="banking-service">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM customer WHERE id = '10000000-0000-0000-0000-000000000002'
            </sqlCheck>
        </preConditions>
        <insert tableName="customer">
            <column name="id" value="10000000-0000-0000-0000-000000000002"/>
            <column name="customer_reference" value="P-0123456790"/>
            <column name="customer_name" value="Testing Customer Number Two"/>
            <column name="status" value="ACTIVE"/>
            <column name="major_display_currency" value="USD"/>
            <column name="created_at" valueComputed="TIMESTAMPTZ '2026-01-01 00:00:00+00'"/>
            <column name="updated_at" valueComputed="TIMESTAMPTZ '2026-01-01 00:00:00+00'"/>
        </insert>
    </changeSet>

